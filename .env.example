# Copia este archivo a .env y completa con tus valores reales.
# Nunca subas .env a Git (esta en .gitignore).

# Supabase (proyecto botslode)
SUPABASE_ANON_KEY=
SUPABASE_URL=

# Mercado Pago (clave publica para checkout)
MP_PUBLIC_KEY=

# Twilio WhatsApp API (mismo numero sender para APEX/Assistify)
API_KEY_SID=
API_KEY_SECRET=
ACCOUNT_SID=

# Content SIDs Empresas (APEX). Descomentar cuando Meta apruebe.
# WPP_EMPRESAS_SID_0=
# WPP_EMPRESAS_SID_1=
WPP_EMPRESAS_SID_2=
WPP_EMPRESAS_SID_3=
WPP_EMPRESAS_SID_4=

# Content SIDs Assistify
WPP_ASSISTIFY_SID_0=
WPP_ASSISTIFY_SID_1=
WPP_ASSISTIFY_SID_2=
WPP_ASSISTIFY_SID_3=
# WPP_ASSISTIFY_SID_4=
